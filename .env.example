# AI provider (server-side only — never expose to the client)
# The provider is OpenAI-compatible: set OPENAI_BASE_URL to use a free endpoint.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# --- Option gratuite A : Ollama (100% local, sans clé) ---
# Installer Ollama, puis : ollama pull llama3.1
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1
# OPENAI_API_KEY=ollama        # valeur factice, non vérifiée en local

# --- Option gratuite B : Groq (cloud, clé gratuite sur console.groq.com) ---
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant
# OPENAI_API_KEY=gsk_...

# Future: provider Claude dédié (voir src/services/ai)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Stockage ---
# Chemin du fichier SQLite. En prod (Docker/Railway), pointer vers un volume
# persistant. Défaut : data/reports.db
# DATABASE_PATH=/app/data/reports.db

# Binaire LibreOffice si non standard (défaut: soffice)
# LIBREOFFICE_BIN=soffice

# --- Envoi du rapport par email (Microsoft Graph / Outlook) ---
# Créer une App registration dans Azure Portal > Microsoft Entra ID :
#   - Compte à locataire unique, URI de redirection Web = MICROSOFT_REDIRECT_URI
#   - Permissions déléguées Graph : Mail.Send, Mail.ReadWrite, offline_access, User.Read
#   - Générer un secret client
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# Clé de chiffrement des tokens en base (AES-256-GCM). Générer avec :
#   openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Fuseau horaire du serveur, utilisé pour l'envoi automatique du vendredi 18h
TZ=Africa/Abidjan
